# StorytellingReferenceBank — Environment Configuration
# Copy to .env and fill in values as needed.

# --- TTS Provider API Keys ---
# Only needed if using cloud providers (ElevenLabs, OpenAI).
# Local providers (Qwen, Kokoro, Coqui) do not require API keys.

# ELEVENLABS_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here

# --- GPU / Device ---
# Force a specific device for TTS inference. Leave unset for auto-detection.
# Options: cuda, cpu, mps (Apple Silicon)
# TTS_DEVICE=cuda

# --- Model Cache ---
# Directory for downloaded model weights. Defaults to ~/.cache/huggingface.
# HF_HOME=/path/to/model/cache

# --- Production Defaults ---
# TARGET_RMS_DB=-20.0
# LIMITER_CEILING_DB=-3.0
# ROOM_TONE_HEAD_SEC=0.5
# ROOM_TONE_TAIL_SEC=3.0
