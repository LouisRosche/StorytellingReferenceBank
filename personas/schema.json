{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TTS Voice Persona",
  "description": "Voice persona definition for Qwen3-TTS audiobook production",
  "type": "object",
  "required": ["id", "name", "voice_prompt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (lowercase, hyphenated)",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Display name for the persona"
    },
    "voice_prompt": {
      "type": "string",
      "description": "Natural language voice description for Qwen3-TTS. Layer: age, gender, accent, texture, pace, emotional baseline."
    },
    "character_context": {
      "type": "string",
      "description": "Optional character background for consistent delivery"
    },
    "reference_audio": {
      "type": "object",
      "description": "Voice cloning reference (5-15 seconds optimal)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to reference audio file"
        },
        "transcript": {
          "type": "string",
          "description": "Exact transcript of reference audio (required for best quality)"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 3,
          "description": "Duration of reference clip (3s minimum, 5-15s optimal)"
        }
      }
    },
    "voice_attributes": {
      "type": "object",
      "description": "Structured attributes for documentation/filtering",
      "properties": {
        "age_range": {
          "type": "string",
          "enum": ["child", "teen", "young_adult", "middle_aged", "elderly"]
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female", "neutral"]
        },
        "pitch": {
          "type": "string",
          "enum": ["very_low", "low", "medium", "high", "very_high"]
        },
        "pace": {
          "type": "string",
          "enum": ["very_slow", "slow", "medium", "fast", "very_fast"]
        },
        "texture": {
          "type": "string",
          "enum": ["smooth", "warm", "breathy", "husky", "gravelly", "crisp"]
        },
        "accent": {
          "type": "string",
          "description": "Primary accent or dialect"
        },
        "languages": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Languages this persona can narrate (Qwen3-TTS supports: en, zh, ja, ko, de, fr, ru, pt, es, it)"
        }
      }
    },
    "emotional_range": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Emotions this persona handles well"
    },
    "use_cases": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Recommended use cases (narrator, dialogue, children's, literary, etc.)"
    },
    "model_variant": {
      "type": "string",
      "enum": ["1.7B-Base", "1.7B-VoiceDesign", "1.7B-CustomVoice", "0.6B"],
      "default": "1.7B-Base",
      "description": "Recommended Qwen3-TTS model variant"
    },
    "notes": {
      "type": "string",
      "description": "Production notes, quirks, or special handling instructions"
    }
  }
}
