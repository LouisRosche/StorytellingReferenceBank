# Stripe keys — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Site URL (required for Stripe redirects and download links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email delivery (optional — falls back to console logging)
# Get from https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=orders@storybooklibrary.com

# File storage (optional — falls back to local content/ directory)
# For Cloudflare R2:
# STORAGE_BUCKET=storybook-library
# STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# STORAGE_AUTH_TOKEN=...
# STORAGE_REGION=auto
#
# For AWS S3:
# STORAGE_BUCKET=storybook-library
# STORAGE_REGION=us-east-1
